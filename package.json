{
  "name": "mdeditor",
  "version": "1.0.0",
  "description": "MDEditor is a markdown editor built with Electron and Milkdown. It provides a seamless writing experience with support for various markdown features, making it an ideal tool for note-taking, documentation, and content creation.",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MZO26/MDEditor.git"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron",
    "tiptap",
    "note-taking",
    "documentation",
    "content creation"
  ],
  "author": "MZO26",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MZO26/MDEditor/issues"
  },
  "homepage": "https://github.com/MZO26/MDEditor#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-details": "^3.22.3",
    "@tiptap/extension-focus": "^3.22.3",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-of-contents": "^3.22.3",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "electron-store": "^8.1.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide": "^0.577.0",
    "zod": "^4.3.6"
  }
}
