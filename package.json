{
  "name": "mdeditor",
  "version": "1.0.0",
  "description": "MZO.md is a fast, distraction-free note-taking app for personal knowledge and documentation",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack:mac": "npm run rebuild && npm run build && electron-builder --mac",
    "pack:win": "npm run rebuild && npm run build && electron-builder --win",
    "pack:linux": "npm run rebuild && npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "de.mzo.md",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": false,
    "productName": "MZO.md",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MZO26/MDEditor.git"
  },
  "keywords": [
    "note-taking-app",
    "local-first-notes",
    "offline-first",
    "developer-notes",
    "editor",
    "electron",
    "tiptap",
    "sqlite",
    "desktop-app",
    "documentation"
  ],
  "author": "MZO26",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MZO26/MDEditor/issues"
  },
  "homepage": "https://github.com/MZO26/MDEditor#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "@types/sanitize-html": "^2.16.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extensions": "^3.22.3",
    "@tiptap/markdown": "^3.23.1",
    "@tiptap/starter-kit": "^3.20.4",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.4.2",
    "electron-context-menu": "^4.1.2",
    "electron-store": "^8.1.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide": "^0.577.0",
    "tinykeys": "^3.0.0",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6"
  }
}
