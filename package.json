{
  "name": "mzo.md",
  "version": "1.0.0",
  "description": "MZO.md is a fast, distraction-free note-taking app for personal knowledge and documentation",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:win": "npm run build && electron-builder --win",
    "pack:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "compression": "normal",
    "appId": "de.mzo.md",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": false,
    "productName": "MZO.md",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json",
      "shared/pdf/**/*",
      "!dist/win-unpacked/**",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "!**/*.map",
      "!**/*.md",
      "!**/.github/**",
      "!**/test/**",
      "!**/__tests__/**",
      "!**/src/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MZO26/MDEditor.git"
  },
  "keywords": [
    "note-taking-app",
    "local-first-notes",
    "offline-first",
    "developer-notes",
    "editor",
    "electron",
    "tiptap",
    "prosemirror",
    "sqlite",
    "desktop-app",
    "documentation"
  ],
  "author": "MZO26",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MZO26/MDEditor/issues"
  },
  "homepage": "https://github.com/MZO26/MDEditor#readme",
  "devDependencies": {
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-list": "^3.26.0",
    "@tiptap/extension-mathematics": "^3.27.4",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extensions": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@types/node": "^26.1.1",
    "dompurify": "^3.4.8",
    "electron": "^43.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "lucide": "^1.17.0",
    "minisearch": "^7.2.0",
    "prosemirror-search": "^1.1.1",
    "tippy.js": "^6.3.7",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
